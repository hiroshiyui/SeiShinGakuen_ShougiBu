[configuration]
entry_symbol = "gdext_rust_init"
compatibility_minimum = 4.3
reloadable = true

[libraries]
linux.debug.x86_64 = "res://native/bin/linux/x86_64/libshogi_core.so"
linux.release.x86_64 = "res://native/bin/linux/x86_64/libshogi_core.so"
android.debug.arm64 = "res://native/bin/android/arm64-v8a/libshogi_core.so"
android.release.arm64 = "res://native/bin/android/arm64-v8a/libshogi_core.so"

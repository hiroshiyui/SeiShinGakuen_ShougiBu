[resource]
script = ExtResource("1_profile")
id = "terry-clark"
display_name = "テリー・クラーク"
portrait_dir = "res://assets/characters/students/terry-clark/"
level = 6
playouts = 512
temperature = 0.3
strength_label = "主将"
tagline = "将棋部の主将"
introduction = "清正学園の1年生で将棋部の主将。海外からの転入生。入部初日に部長の中村アリスを破り、『私の友 ── あなたなら誰のことか分かるはずだ ── が今も待っている。あの日、指し終わらなかった一局を完成させるために』と告げた。部内最強の実力者でありながら、それ以来部員とは一切指さず、吉田顧問と加藤師範とだけ対局を続けている。"
